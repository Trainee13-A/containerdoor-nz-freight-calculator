// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model AppSetting {
  id                         String   @id @default(cuid())
  shop                       String   @unique
  fuelSurchargePercent       Decimal  @default(0) @db.Decimal(10, 2)
  additionalCostType         CostType @default(FIXED)
  additionalCostValue        Decimal  @default(0) @db.Decimal(10, 2)
  defaultCurrency            String   @default("NZD")
  defaultServiceType         ServiceType @default(STANDARD_DELIVERY)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt
}

model ShippingRate {
  id             String      @id @default(cuid())
  shop           String
  company        CarrierCompany
  serviceType    ServiceType
  city           String
  postalCode     String
  useWeightRange Boolean     @default(false)
  minWeightGrams Int?
  maxWeightGrams Int?
  useVolumeRange Boolean     @default(false)
  minVolumeCm3   Int?
  maxVolumeCm3   Int?
  rate           Decimal     @db.Decimal(10, 2)
  zoneSurcharge  Decimal     @default(0) @db.Decimal(10, 2)
  mode           CarrierMode?
  active         Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([shop, active, company, serviceType])
  @@index([shop, city, postalCode])
}

enum CostType {
  FIXED
  PERCENTAGE
}

enum CarrierCompany {
  FLIWAY
  NZP
  CASTLE
  TGE
  M2H
  MAINFREIGHT
}

enum ServiceType {
  STANDARD_DELIVERY
  DEPOT_DELIVERY
  CUSTOMER_PICKUP
}

enum CarrierMode {
  AIR
  ROAD
}
